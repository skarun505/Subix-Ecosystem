# ============================================
# Subix Ecosystem — Environment Variables
# ============================================
# Copy this file as .env and fill in real values

# Supabase (shared across all apps)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# App URLs
WEB_URL=https://subix.in
ACCOUNTS_URL=https://accounts.subix.in
LEADOS_URL=https://leados.subix.in
HRMS_URL=https://hrms.subix.in
