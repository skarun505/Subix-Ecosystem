# 1. Disable MultiViews to prevent conflict with rewrite rules
Options -MultiViews -Indexes
ErrorDocument 404 /404.html

RewriteEngine On

# 2. Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. Strip .html from the end of URLs (External Redirect for SEO)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# 4. Internally forward /file to /file.html 
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L,QSA]

# 5. Internally forward /dir to /dir/index.html 
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.*)$ $1/index.html [L,QSA]
